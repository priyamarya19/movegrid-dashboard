# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude code local state
.claude

# typescript
*.tsbuildinfo
next-env.d.ts

# dev server log
.dev.log

# raw rider PII from ops sheets / generated reports — lives in the database,
# not in git. Real names, mobiles, Aadhaar/PAN/bank doc links, addresses.
/data update/
# full DB dumps taken before destructive rebuilds — PII + auth password hashes
/backups/
/rider-rent-report.csv
/sheet-rent-report.csv
/scripts/rent-jul.csv
/scripts/allotments.csv
/scripts/fleet-data.json

# vendor API collection with an embedded real credential
/postman/\[PROD\]*.postman_collection.json
